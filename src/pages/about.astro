---
import Layout from "src/layouts/Layout.astro";
import Whoami from "src/components/Whoami.astro";
import NeroneModal from "src/components/NeroneModal.astro";

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://francescojames.dev" },
    { "@type": "ListItem", "position": 2, "name": "About Me", "item": "https://francescojames.dev/about" }
  ]
};
---

<Layout
  justifyType="start"
  showFab={true}
  title="Francesco James - About Me"
  description="Learn about Francesco James Fanti, a developer bridging web technologies and cloud solutions with a passion for innovative problem-solving."
  canonical="https://francescojames.dev/about"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
  </Fragment>

<Whoami />
  <div id="about-section" class="font-montserrat animate-about-fade-in">

  <h1 class="font-bold text-xl">Some facts <span class="italic">about me</span></h1>
  <h2 class="font-medium text-lg pb-10">aka what i do for...</h2>
  <h3 class="font-bold text-lg">a living:</h3>
  <h4 class="font-medium text-md leading-relaxed pb-6">
    <p>I'm a developer who bridges modern technologies with a talent in innovative problem-solving.</p>
    <p>My work spans modern web development and cloud based architectures,</p>
    <p>always with an eye toward practical, forward-thinking solutions.</p>
    <p>I believe in maintaining sharp focus on core skills while embracing complementary disciplines and lateral thinking.</p>
    <p>This approach makes me adaptable and valuable in dynamic, modern environments.</p>
    <br/>
    <p>I also love <span class="italic font-bold">repairing hardware</span>, pc building and maintenance.</p>
    <p class="pt-2">You can learn more about it in my <a class="link link-accent font-bold" href="/skills">skills page</a>;</p>
    <p>take a look at my projects on <a class="link link-info font-bold" href="https://github.com/neosnakex34" target="_blank" rel="noopener noreferrer">github</a>;</p>
  <p>download my updated <a class="link link-info font-bold" href="https://github.com/neoSnakex34/cv-typst/raw/master/main.pdf" download>CV</a><span class="text-xs"> (with contacts)</span></p>
  </h4>

  <!-- TODO link other stuff -->
  <h3 class="font-bold text-lg">hobby:</h3>
  <h4 class="font-medium text-md leading-relaxed pb-6">
    <p>In my free time, I love looking after the neighborhood <span role="button" aria-label="triggers the opening of a modal showing a cat pic" class="link link-base font-bold" onclick="my_modal_1.showModal()">stray cats</span>,</p>
    <p>playing <a class="link font-bold" href="https://en.wikipedia.org/wiki/Balatro" target="_blank" rel="noopener noreferrer">balatro</a>, <a class="link link-base font-bold" href="https://en.wikipedia.org/wiki/Days_at_the_Morisaki_Bookshop" target="_blank" rel="noopener noreferrer">reading novels</a></p>
    <p>or go full creative on drawing or painting.</p>
    <p>You may consider giving my <a class="link link-success font-bold" href="/blog">blog</a> a read.</p>
  </h4>
  </div>
  <NeroneModal />
</Layout>
