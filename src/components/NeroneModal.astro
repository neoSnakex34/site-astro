---
import { Image } from "astro:assets";
import nerone from "src/assets/nerone2.jpg";
// import nerone2 from "src/assets/nerone2.jpg";
import milo from "src/assets/milo.jpg";
import cherie from "src/assets/cherie.jpg";

const slideTexts = {
  slide1: "She is Mimì (but I call her Nerone)",
  slide2: "He is Felix (or Tempesta, but I call him Milo), the new arrival to the stray cat community",
  slide3: "She is Cherie, a cute affectionate cat"
};

---

<dialog id="my_modal_1" class="modal">
  <div class="modal-box w-11/12 max-w-2xl p-0 overflow-hidden">
    <!-- Carousel container -->
    <div class="carousel w-full relative">
      <!-- Slide 1 -->
      <div id="slide1" class="carousel-item w-full">
        <div class="w-full relative">
          <Image
            src={nerone}
            alt="nerone, one of the stray cats I look after"
            class="w-full aspect-[804/714] object-cover"
          />
          <div class="absolute inset-0 flex items-center justify-between px-4 pointer-events-none">
            <a href="#slide3" class="btn btn-circle btn-sm pointer-events-auto">❮</a>
            <a href="#slide2" class="btn btn-circle btn-sm pointer-events-auto">❯</a>
          </div>
        </div>
      </div>

      <!-- Slide 2 -->
      <div id="slide2" class="carousel-item w-full">
        <div class="w-full relative">
          <Image
            src={milo}
            alt="milo, the new arrived on the stray cats community"
            class="w-full aspect-[804/714] object-cover"
          />
          <div class="absolute inset-0 flex items-center justify-between px-4 pointer-events-none">
            <a href="#slide1" class="btn btn-circle btn-sm pointer-events-auto">❮</a>
            <a href="#slide3" class="btn btn-circle btn-sm pointer-events-auto">❯</a>
          </div>
        </div>
      </div>

      <div id="slide3" class="carousel-item w-full">
        <div class="w-full relative">
          <Image
            src={cherie}
            alt="cherie, one of the stray cats I look after"
            class="w-full aspect-[804/714] object-cover"
          />
          <div class="absolute inset-0 flex items-center justify-between px-4 pointer-events-none">
            <a href="#slide2" class="btn btn-circle btn-sm pointer-events-auto">❮</a>
            <a href="#slide1" class="btn btn-circle btn-sm pointer-events-auto">❯</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal content below carousel -->
    <div class="p-6">
        <p id="modal-text" class="font-montserrat font-semibold mb-4"></p>
      <div class="modal-action">
        <form method="dialog">
          <!-- if there is a button in form, it will close the modal -->
          <button class="btn">Close</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Click outside to close -->
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script>
  const slideTexts = {
    slide1: "She is Mimì (but I call her Nerone)",
    slide2: "He is Felix (or Tempesta, but I call him Milo), the new arrival to the stray cat community",
    slide3: "She is Cherie, a cute affectionate cat"
  };

  const modalText = document.getElementById('modal-text');
  const modal = document.getElementById('my_modal_1');
  const carousel = modal.querySelector('.carousel');

  let currentSlide = 'slide1';

  function updateText() {
    modalText.textContent = slideTexts[currentSlide] || slideTexts.slide1;
  }

  function setSlide(slideId) {
    currentSlide = slideId;
    carousel.querySelectorAll('.carousel-item').forEach((item, index) => {
      item.classList.toggle('w-full', item.id === slideId);
    });
    updateText();
  }

  function resetToFirstSlide() {
    currentSlide = 'slide1';
    setSlide('slide1');
  }

  // Intercept carousel navigation links
  modal.querySelectorAll('.carousel a[href^="#slide"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetSlide = link.getAttribute('href').substring(1);
      setSlide(targetSlide);
    });
  });

  // Handle touch swipe - use IntersectionObserver for active slide detection
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        currentSlide = entry.target.id;
        updateText();
      }
    });
  }, { threshold: 0.5 });

  carousel.querySelectorAll('.carousel-item').forEach(item => {
    observer.observe(item);
  });

  // Reset to first slide when modal opens (with debounce)
  let openTimeout;
  modal.addEventListener('open', () => {
    clearTimeout(openTimeout);
    openTimeout = setTimeout(() => {
      resetToFirstSlide();
    }, 50);
  });

  modal.addEventListener('close', () => {
    modalText.textContent = slideTexts.slide1;
  });

  updateText();
</script>
